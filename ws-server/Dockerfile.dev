FROM node:20-alpine

# ビルドツールの追加
RUN apk add --no-cache python3 make g++

WORKDIR /app

# 1. ルートから両方の package.json をコピー（キャッシュ効率のため）
COPY ws-server/package*.json ./ws-server/
COPY next/package*.json ./next/

# 2. ws-server の依存関係をインストール
WORKDIR /app/ws-server
RUN node -e "const p=require('./package.json'); delete p.dependencies['@torassen/shogi-logic']; require('fs').writeFileSync('./package.json', JSON.stringify(p,null,2))"
RUN npm install

# 3. ★ここが最重要：コンテナ内に両方のソースコードをコピーする
WORKDIR /app
COPY ws-server/ ./ws-server/
COPY next/ ./next/

# 4. ws-server に戻ってビルド
WORKDIR /app/ws-server
RUN npm run build

EXPOSE 3001
CMD ["npm", "run", "dev"]
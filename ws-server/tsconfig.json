{
	"compilerOptions": {
		"target": "ES2020",
		"module": "commonjs",
		"lib": [
			"ES2020",
			"DOM"
		],
		"outDir": "./dist",
		// "rootDir": "./src",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"baseUrl": ".",
		"paths": {
			"@torassen/shogi-logic": [
				"../packages/shogi-logic/src/index.ts"
			],
			"@torassen/shogi-logic/*": [
				"../packages/shogi-logic/src/*"
			],
		}
	},
	"include": [
		"src/**/*",
		"../packages/shogi-logic/src/**/*"
	],
	"exclude": [
		"node_modules",
		"dist"
	]
}
{
	"compilerOptions": {
		"lib": [
			"dom",
			"dom.iterable",
			"esnext"
		],
		"allowJs": true,
		"skipLibCheck": true,
		"strict": true,
		"noEmit": true,
		"types": [
			"@react-three/fiber"
		],
		"esModuleInterop": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"jsx": "preserve",
		"incremental": true,
		"plugins": [
			{
				"name": "next"
			}
		],
		"paths": {
			"@/*": [
				"./*"
			],
			"@torassen/shogi-logic": [
				"../packages/shogi-logic/src"
			],
			"@torassen/shogi-logic/*": [
				"../packages/shogi-logic/src/*"
			]
		}
	},
	"include": [
		"next-env.d.ts",
		"three-elements.d.ts",
		"**/*.ts",
		"**/*.tsx",
		".next/types/**/*.ts"
	],
	"exclude": [
		"node_modules"
	]
}